{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "naturalcontrol.estimation_prediction.v1.schema.json",
  "title": "NaturalControl Estimation Prediction v1",
  "description": "Estimation-layer payload for future predicted subject state. This line formalizes prediction horizons without redefining interaction or actuation semantics.",
  "type": "object",
  "required": [
    "schema_id",
    "spec_version",
    "epoch_ns",
    "prediction_id",
    "source_observation_id",
    "horizon_ns",
    "coordinate_space",
    "subjects"
  ],
  "properties": {
    "schema_id": {
      "const": "naturalcontrol.estimation_prediction.v1"
    },
    "spec_version": {
      "const": "1.0"
    },
    "epoch_ns": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nsValue"
    },
    "prediction_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "source_observation_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "request_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "interaction_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "horizon_ns": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nsValue"
    },
    "coordinate_space": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/coordinateSpace"
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/predictedSubject"
      }
    },
    "meta": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/metaObject"
    }
  },
  "$defs": {
    "vector3": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "properties": {
        "radius": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "predictedSubject": {
      "type": "object",
      "required": [
        "subject_id",
        "confidence"
      ],
      "properties": {
        "subject_id": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
        },
        "confidence": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/probability"
        },
        "bbox2d": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/bbox"
        },
        "point2d": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/vector2"
        },
        "position3d": {
          "$ref": "#/$defs/vector3"
        },
        "velocity": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/vector2"
        },
        "acceleration": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/vector2"
        },
        "uncertainty": {
          "$ref": "#/$defs/uncertainty"
        },
        "model_ref": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nonEmptyString"
        },
        "meta": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/metaObject"
        }
      },
      "anyOf": [
        {
          "required": [
            "bbox2d"
          ]
        },
        {
          "required": [
            "point2d"
          ]
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
