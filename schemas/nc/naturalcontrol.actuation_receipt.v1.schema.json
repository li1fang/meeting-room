{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "naturalcontrol.actuation_receipt.v1.schema.json",
  "title": "NaturalControl Actuation Receipt v1",
  "description": "Actuation-layer receipt payload for bundle-side acceptance and emission state. This line does not replace lifecycle reporting.",
  "type": "object",
  "required": [
    "schema_id",
    "spec_version",
    "epoch_ns",
    "receipt_id",
    "bundle_id",
    "execution_id",
    "surface_kind",
    "receipt_state"
  ],
  "properties": {
    "schema_id": {
      "const": "naturalcontrol.actuation_receipt.v1"
    },
    "spec_version": {
      "const": "1.0"
    },
    "epoch_ns": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nsValue"
    },
    "receipt_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "bundle_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "request_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "interaction_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "execution_id": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
    },
    "surface_kind": {
      "type": "string",
      "enum": ["mouse", "touch", "gamepad", "gear", "unknown"]
    },
    "receipt_state": {
      "type": "string",
      "enum": ["accepted", "emitted", "partial", "rejected"]
    },
    "adapter_ref": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nonEmptyString"
    },
    "emitted_atom_count": {
      "type": "integer",
      "minimum": 0
    },
    "rejected_atom_refs": {
      "type": "array",
      "items": {
        "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "error": {
      "type": "object",
      "required": ["code", "reason"],
      "properties": {
        "code": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nonEmptyString"
        },
        "reason": {
          "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "$ref": "naturalcontrol.common.v1.2.schema.json#/$defs/metaObject"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "rejected"
          }
        },
        "required": ["receipt_state"]
      },
      "then": {
        "required": ["error"]
      }
    },
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "partial"
          }
        },
        "required": ["receipt_state"]
      },
      "then": {
        "anyOf": [
          { "required": ["emitted_atom_count"] },
          { "required": ["rejected_atom_refs"] }
        ]
      }
    }
  ],
  "additionalProperties": false
}
